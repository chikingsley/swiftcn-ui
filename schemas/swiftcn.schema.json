{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "fileLayout": {
      "default": "flat",
      "enum": [
        "flat",
        "registry"
      ]
    },
    "formatSwift": {
      "default": true,
      "description": "Run Apple swift format with the consumer's .swift-format before writing and hashing source.",
      "type": "boolean"
    },
    "includePreviews": {
      "default": false,
      "type": "boolean"
    },
    "platform": {
      "enum": [
        "macOS",
        "iOS",
        "iPadOS"
      ]
    },
    "registry": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "target": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "registry",
    "target",
    "platform",
    "includePreviews",
    "fileLayout",
    "formatSwift"
  ],
  "title": "SwiftCN consumer configuration",
  "type": "object"
}
